{
  "remarks": "🧠 NL gRPC (low latency)",
  "log": { "loglevel": "error" },
  "inbounds": [
    {
      "tag": "socks-in",
      "port": 10808,
      "listen": "127.0.0.1",
      "protocol": "socks",
      "settings": { "udp": true }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "45.131.210.12",
            "port": 443,
            "users": [
              {
                "id": "b1c2d3e4-f5a6-47b8-91c2-3d4e5f6a7b88",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "grpc",
        "security": "tls",
        "sockopt": {
          "tcpFastOpen": true,
          "tcpNoDelay": true
        },
        "grpcSettings": {
          "serviceName": "grpc"
        }
      }
    }
  ]
}
