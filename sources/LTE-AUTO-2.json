{
  "remarks": "🇷🇺 LTE AUTO (VLESS+SS)",
  "log": { "loglevel": "warning" },
  "dns": { "servers": ["https://1.1.1.1/dns-query", "1.1.1.1"] },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "port": 10808,
      "protocol": "socks",
      "settings": { "auth": "noauth", "udp": true },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls", "quic"] }
    },
    {
      "listen": "127.0.0.1",
      "port": 10809,
      "protocol": "http",
      "sniffing": { "enabled": true, "destOverride": ["http", "tls", "quic"] }
    }
  ],
  "observatory": {
    "enabled": true,
    "probeURL": "https://www.gstatic.com/generate_204",
    "probeInterval": "30s",
    "subjectSelector": ["vless-proxy", "ss-proxy"]
  },
  "outbounds": [
    {
      "tag": "vless-proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [{
          "address": "93.77.169.139",
          "port": 56747,
          "users": [{
            "id": "{UUID}",
            "encryption": "none",
            "flow": "xtls-rprx-vision"
          }]
        }]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "m.vk.com",
          "fingerprint": "random",
          "publicKey": "xMLmloCjTnGFy3mz32k54Ynq_JCIc28ju2Ajb3xX9Co",
          "shortId": "707f9f44e2b21d87"
        }
      }
    },
    {
      "tag": "ss-proxy",
      "protocol": "shadowsocks",
      "settings": {
        "servers": [{
          "address": "93.77.169.139",
          "port": 56748,
          "method": "2022-blake3-aes-128-gcm",
          "password": "UKr1956qZbGPG7iuNBsTC-AaobSup-U0Yd0p0mFdwUE"
        }]
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom"
    }
  ],
  "balancer": {
    "tag": "balance",
    "selector": ["vless-proxy", "ss-proxy"],
    "strategy": {
      "type": "leastPing",
      "settings": { "observatory": "observatory" }
    }
  },
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      { "type": "field", "inboundTag": ["socks", "http"], "balancerTag": "balance" }
    ]
  }
}
