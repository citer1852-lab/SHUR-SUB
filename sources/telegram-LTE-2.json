{
  "remarks": "🇷🇺Telegram + LTE",
  "log": { "loglevel": "warning" },
  "dns": {
    "servers": [
      "https://1.1.1.1/dns-query",
      "1.1.1.1"
    ],
    "queryStrategy": "UseIPv4"
  },
  "inbounds": [
    {
      "listen": "127.0.0.1",
      "port": 10808,
      "protocol": "socks",
      "settings": { "auth": "noauth", "udp": true },
      "sniffing": { "enabled": true, "destOverride": ["http", "tls", "quic"] },
      "tag": "socks"
    },
    {
      "listen": "127.0.0.1",
      "port": 10809,
      "protocol": "http",
      "sniffing": { "enabled": true, "destOverride": ["http", "tls", "quic"] },
      "tag": "http"
    }
  ],
  "observatory": {
    "enabled": true,
    "probeURL": "https://www.gstatic.com/generate_204",
    "probeInterval": "30s",
    "probeTimeout": "5s"
  },
  "outbounds": [
    {
      "tag": "ms",
      "protocol": "vless",
      "settings": {
        "vnext": [{
          "address": "93.77.169.139",
          "port": 6443,
          "users": [{ "id": "{UUID}", "flow": "xtls-rprx-vision", "encryption": "none" }]
        }]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "www.microsoft.com",
          "fingerprint": "randomized",
          "publicKey": "xMLmloCjTnGFy3mz32k54Ynq_JCIc28ju2Ajb3xX9Co",
          "shortId": "707f9f44e2b21d87"
        }
      }
    },
    {
      "tag": "vk",
      "protocol": "vless",
      "settings": {
        "vnext": [{
          "address": "93.77.169.139",
          "port": 6443,
          "users": [{ "id": "{UUID}", "flow": "xtls-rprx-vision", "encryption": "none" }]
        }]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "m.vk.com",
          "fingerprint": "randomized",
          "publicKey": "xMLmloCjTnGFy3mz32k54Ynq_JCIc28ju2Ajb3xX9Co",
          "shortId": "707f9f44e2b21d87"
        }
      }
    },
    {
      "tag": "yandex",
      "protocol": "vless",
      "settings": {
        "vnext": [{
          "address": "93.77.169.139",
          "port": 6443,
          "users": [{ "id": "{UUID}", "flow": "xtls-rprx-vision", "encryption": "none" }]
        }]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "api-maps.yandex.ru",
          "fingerprint": "randomized",
          "publicKey": "xMLmloCjTnGFy3mz32k54Ynq_JCIc28ju2Ajb3xX9Co",
          "shortId": "707f9f44e2b21d87"
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": { "domainStrategy": "UseIP" }
    }
  ],
  "balancer": {
    "tag": "balance",
    "selector": ["ms", "vk", "yandex"],
    "strategy": {
      "type": "roundRobin",
      "settings": { "fallbackTag": "direct" }
    },
    "observatory": "observatory"
  },
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      { "type": "field", "inboundTag": ["socks", "http"], "outboundTag": "balance" }
    ]
  }
}
