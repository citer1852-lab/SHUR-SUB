{
  "remarks": "⚡ CF CDN WS (stable fallback)",
  "log": { "loglevel": "error" },
  "inbounds": [
    {
      "tag": "socks-in",
      "port": 10808,
      "listen": "127.0.0.1",
      "protocol": "socks",
      "settings": { "udp": true }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "104.21.72.198",
            "port": 443,
            "users": [
              {
                "id": "a7f3e1c2-6d9a-4b2e-91c3-5a7c2d9e1f44",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "tls",
        "sockopt": {
          "tcpFastOpen": true,
          "tcpNoDelay": true
        },
        "wsSettings": {
          "path": "/vless",
          "headers": {
            "Host": "cdnjs.cloudflare.com"
          }
        }
      },
      "mux": {
        "enabled": true,
        "concurrency": 8
      }
    }
  ]
}
